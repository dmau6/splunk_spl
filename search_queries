modified_properties=mvmap(modified_properties, json_object(mvindex(split(modified_properties, ":"), 0))), mvindex(split(modified_properties, ":"), 1),  mvindex(split(modified_properties, ":"), 2))),
modified_properties="[".mvjoin(modif, ",")."]"
| eval modified_properties=mvzip('modified_properties{}.name', 'modified_properties{}.value', ":"),
modified_properties=mvmap(modified_properties, json_object(mvindex(split(modified_properties, ":"), 0), mvindex(split(modified_properties, ":"), 1))),
modified_properties="[".mvjoin(modified_properties, ",")."]"
| spath input=modified_properties

#Health Alerts
#Finding the top 20 reporting st 
index=_internal sourcetype=splunkd source=*license_usage.log type=Usage earliest=-8d@d
    [search index=_internal sourcetype=splunkd source=*license_usage.log type=Usage
    | stats sum(b) as bytes by st
    | sort -bytes
    | head 25
    | table st]
| timechart limit=0 span=1d@d sum(eval(round(b/1024/1024/28672,2))) as "MB" by st

#Percentage of Searches within 24 hours
index="_audit" sourcetype=audittrail action=search api_et=* api_lt=* | eval Past=tostring(round(api_lt-api_et),"duration") | eval over_under=IF(LIKE(Past, "%+%"), "over_24", "under_24")

#Long Running Searches
index=_audit action=search (id=* OR search_id=*)|eval user=if(user=="n/a", null(), user)|stats max(total_run_time) as total_run_time first(user) as user by search_id |stats count perc95(total_run_time) median(total_run_time) by user

