#Using SPATH with MVZIP, MVEXPAND
index=ontap sourcetype=ontap:audit
| spath output=Data path=Event.EventData.Data
| spath output=Name path=Event.EventData.Data{@Name}
| table Data, Name
| eval x=mvzip(Data, Name)
| mvexpand x
| eval x = split(x,",") 
| eval data=mvindex(x,0)  | eval name=mvindex(x,1)

#Attack surface trends from Crowdstrike using spath, mvexpand, nomv
index=surface_alerts
| fields confidence, asset_type, id, ip.ptr, discovery, entity_type, ip.fqdns{},"discovery.path.steps{}.clue", "discovery.path.steps{}.entity_type", "discovery.path.steps{}.entity", "ip.services{}.applications{}.category", ip.location.country_name, ip.location.region_name, "ip.services{}.status"
| spath discovery.path.steps{}.clue
| spath discovery.path.steps{}.entity_type
| spath discovery.path.steps{}.entity
| spath ip.services{}.applications{}.category
| spath ip.location.country_name
| spath ip.location.region_name
| spath ip.services{}.status
| spath ip.fqdns{}
| rename "discovery.path.steps{}.clue" as "Clue", "discovery.path.steps{}.entity_type" as "Type", "discovery.path.steps{}.entity" as "Attack Surface", "ip.services{}.applications{}.category" as "Application Category", "ip.location.country_name" as "Country", "ip.location.region_name" as "State", "ip.services{}.status" as "IP Status", "ip.fqdns{}, discovery.path.steps{}.clue" as discovery_clue
| table confidence, asset_type, id, ip.ptr, discovery, entity_type, "Type", "Clue", "Attack Surface" ,"Application Category", "Country", "State", "IP Status", "discovery_clue"
| mvexpand "Clue"
| mvexpand "Type"
| mvexpand "Attack Surface"
| nomv "Clue"
| nomv "Type"
| nomv "Attack Surface"
| table id, "Attack Surface", "Clue", "Type"

#Number of open vulnerabilities by status per host
index=crowdstrike_endpoint sourcetype="crowdstrike:spotlight:vulnerability:json"
| rename falcon_spotlight.* as *
| eval status=CASE(status="expired", "closed", status="open", "open", status="reopen", "open", status="closed", "closed", 1==1, NULL())
| fields status

index=crowdstrike_endpoint sourcetype="crowdstrike:spotlight:vulnerability:json"
| rename falcon_spotlight.* as *
| eval status=CASE(status="expired", "closed", status="open", "open", status="reopen", "open", status="closed", "closed", 1==1, NULL())
| table vulnerability_id, status, cve.base_score, host_info.asset_criticality, host_info.hostname, closed_timestamp, created_timestamp
| stats count last(status) as status by host_info.hostname, vulnerability_id

#Vulnerability status by base score
index=crowdstrike_endpoint sourcetype="crowdstrike:spotlight:vulnerability:json"
| rename falcon_spotlight.* as *
| eval status=CASE(status="expired", "closed", status="open", "open", status="reopen", "open", status="closed", "closed", 1==1, NULL())
| table vulnerability_id, status, cve.base_score, host_info.asset_criticality, host_info.hostname, closed_timestamp, created_timestamp
| eventstats sum(cve.base_score) as base_score by vulnerability_id, host_info.hostname
| chart count over status by base_score

#Indicator trends
index=surface_alerts
| streamstats latest(last_seen) as last_seen by id
| eval x=mvzip(clue, mvzip(threat_class, indicator))
| mvexpand x
| eval x = split(x,",")
| eval clue=mvindex(x, 0)
| eval threat_class=mvindex(x, 1)
| eval indicator=mvindex(x,2)
| eval message="The ".clue." was a(n) ".." and with value ".indicator
| fields message, id
| rex field=id "e59a6a3d526240208f1dd0b2ece2ca20_(?<id>\S+)"
| stats values(message) as messages by id

#Threat Class Categorization
index=surface_alerts
| streamstats latest(last_seen) as last_seen by id
| eval x=mvzip(clue, mvzip(threat_class, indicator))
| mvexpand x
| eval x = split(x,",")
| eval clue=mvindex(x, 0)
| eval threat_class=mvindex(x, 1)
| eval indicator=mvindex(x,2)
| eval message="The ".clue." was a(n) ".threat_class." with value ".indicator| rex field=id "[redacted]_(?<correlation>\S+)"| stats values(message) as message by ip.ip_address, indicator

#Regex for crowdstrike vulnerability to calculate risk
| rex field=falcon_spotlight.cve.vector "CVSS3\.1\/AV\:(?<Attack Vector>\w{1,2})\/AC\:(?<Attack Complexity>\w)\/PR(?<Privileges Required>\w)\/UI\:(?<User Interaction>\w)\/S\:(?<Scope>\w)\/C\:(?<Confidentiality Impact>\w)\/I\:(?<Integrity Impact>\w)\/A(?<Availability Impact>\w)"

#Internet facing alerts
index==surface_alerts internet_exposure=yes
| rename discovery.path.steps{}.clue as "domain"
| rename discovery.path.steps{}.entity as "ioc"
| eval x=mvzip(domain,ioc)
| mvexpand x
| eval y=split(x, ",")
| eval domain=mvindex(y, 0)
| eval hint=mvindex(y, 1)
| eval domain=IF(LIKE(domain, "%DNS%"), "IP is resolved from DNS", domain)
| eval message="The ".domain.” : ".hint
| eventstats dc(correlation_id) as number by message
| rex field=message "The\s(?<category>\S+)[^\:]+\:\s(?<value>[^\"]+)"
| chart count(number) as total over category by value

#ServiceNow Metrics
#Triage times per incident
index=snow sourcetype="snow:incident"
| fields active, state, short_description, dv_assignment_group, sla_due, impact, priority, severity, dv_business_service, category, subcategory, dv_assigned_to, dv_comments_and_work_notes, _time, number, dv_sys_updated_on, dv_sys_created_on
| eval Severity=impact*priority
| search active=false
| eval Closed = strptime(dv_sys_updated_on, "%Y-%m-%d %H:%M:%S")
| eval Opened=strptime(dv_sys_created_on,"%Y-%m-%d %H:%M:%S")
| eval "total_time"=Closed - Opened
| convert timeformat="%H hours %m minutes" ctime(total_time)
| convert timeformat="%a %B %d %H:%M:%S.%N %Y" ctime(Start)
| eval SLA=strptime(sla_due, "%Y-%m-%d %H:%M:%S")
| eval "met_sla" = IF(SLA > Closed, "Yes", "No")
| eval Triage_Closed=IF("met_sal"="Yes", dv_sys_updated_on, "Still in Triage")
| rename short_description as "Description", active as "Status", "dv_assignment_group" as "Assigned Group", "sla_due" as "Service Level Agreement Triage Time", dv_assigned_to as "Analyst", dv_comments_and_work_notes as "Notes", dv_sys_created_on as "Start", category as Category, number as "Incident ID", "dv_business_service" as "Business Unit", subcategory as Subcategory. "met_sla" as "Met SLA"
| table "Incident ID", Description, Severity, "Met SLA", "Assigned Group", Analyst, "Business Unit", Start, Notes

